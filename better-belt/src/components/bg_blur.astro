---
import backgroundImage from '../assets/plagi_deteccio.svg'; 
---

<div class="main-container">
  <div class="background-image" aria-hidden="true"></div>
  
  <div class="content">
    <h1>Título Principal</h1>
    <p>Texto sobre fondo con blur.</p>
  </div>
</div>

<style define:vars={{ bgUrl: `url(${backgroundImage.src})` }}>
  .main-container {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden; /* Mantiene el scale(1.1) dentro de los límites */
    display: grid;   /* Opción: usar grid para centrar contenido fácilmente */
    place-items: center;
  }

  .background-image {
    position: absolute;
    inset: 0; /* Atajo moderno para top/right/bottom/left: 0 */
    background-image: var(--bgUrl);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    
    filter: blur(8px);
    transform: scale(1.1); 
    z-index: 1;
  }

  .content {
    position: relative;
    z-index: 2;
    color: white;
    text-align: center;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }
</style>
