---
import background from '../assets/background.svg';

const categories = [
  {
    label: 'Servidor',
    items: [
      { name: 'spaCy', role: 'Detección de LN', color: '#8e78f1', icon: '🧠' },
      { name: 'Simhash', role: 'Detección de duplicados', color: '#8e78f1', icon: '🔗' },
      { name: 'ChromaDB', role: 'Busqueda similitud vectorial', color: '#8e78f1', icon: '📐' },
      { name: 'Cosine Similarity', role: 'Detección de similitudes', color: '#8e78f1', icon: '📊' },
    ]
  },
  {
    label: 'Modelo',
    items: [
      { name: 'AST', role: 'Analisis Estructural', color: '#e0f2fe', icon: '🌳' },
    ]
  },
  {
    label: 'Herramientas',
    items: [
      { name: 'WCopyfind', role: 'Detección de coincidencias', color: '#fff3e0', icon: '🔍' },
      { name: 'PyPDF', role: 'Extracción de texto', color: '#dcd0be', icon: '📄' }
    ]
  },
];
---

<div id="container">
  <div id="bg-wrapper" aria-hidden="true">
    <img id="background-img" src={background.src} alt="" fetchpriority="high" />
  </div>

  <main>
    <section id="hero">
      <div id="badge">Project Stack</div>
      <h1>Anyelolol Stack</h1>
      <h2>PlagDec</h2>
      <p class="description">
        PlagDec es un módulo basado en inteligencia artificial diseñado para la detección de plagio en documentos digitales. 
        El sistema combina técnicas de procesamiento de lenguaje natural y análisis estructural.
      </p>

      <div id="categories">
        {categories.map(cat => (
          <div class="category">
            <span class="cat-label">{cat.label}</span>
            <div class="grid">
              {cat.items.map(item => (
                <div class="card">
                  <div class="icon" style={`background:${item.color}`}>{item.icon}</div>
                  <span class="name">{item.name}</span>
                  <span class="role">{item.role}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</div>

<style>
  /* Contenedor del fondo para evitar bordes blancos por el blur */
  #bg-wrapper {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background-color: #f9fafb; /* Color base por si la imagen tarda en cargar */
  }

  #background-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Un blur de 100px es muy alto, 40-60px suele verse más elegante */
    filter: blur(60px); 
    /* El scale compensa el desenfoque en los bordes */
    transform: scale(1.2); 
  }

  #container {
    font-family: 'Inter Variable', Inter, sans-serif;
    min-height: 100vh;
  }

  main {
    display: flex;
    justify-content: center;
    padding: 4rem 1.5rem;
  }

  #hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    max-width: 800px;
    width: 100%;
  }

  #badge {
    background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h1 { font-size: 2.5rem; font-weight: 800; margin: 0; color: #111827; letter-spacing: -0.02em; }
  h2 { font-size: 1.5rem; color: #4b5563; margin: -8px 0 0; }
  .description { font-size: 1.1rem; color: #4b5563; line-height: 1.6; max-width: 65ch; }

  #categories {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
    margin-top: 2rem;
  }

  .category { display: flex; flex-direction: column; gap: 12px; }
  
  .cat-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }

  .card {
    /* Fondo semi-transparente para el efecto Glassmorphism */
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 20px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    backdrop-filter: blur(12px); /* Esto hace que la card se vea "frosted glass" */
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05);
  }

  .name { font-size: 0.9rem; font-weight: 600; color: #111827; }
  .role { font-size: 0.75rem; color: #6b7280; text-align: center; line-height: 1.3; }

  @media (max-width: 600px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    h1 { font-size: 2rem; }
  }
</style>